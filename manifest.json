{
  "manifest_version": 3,
  "name": "ZPL Label Preview",
  "version": "1.0.0",
  "description": "Watch a PlexComponentHost log file for ZPL print data, render via labelary.com, and preview/download label images.",
  "permissions": [
    "storage",
    "alarms",
    "downloads",
    "notifications",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://api.labelary.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "ZPL Label Preview"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
